{
  "kinshoutApi": {
    "baseUrl": "http://localhost:5000",
    "importPath": "/api/imports/adverts",
    "importKey": "dev-kinshout-import-secret-change-me",
    "batchSize": 100
  },
  "schedule": {
    "runOnce": true,
    "intervalHours": 24,
    "maxAdvertAgeDays": 60
  },
  "providers": [
    {
      "name": "MediaCongo Kinshasa scraper",
      "provider": "mediacongo",
      "providerName": "MediaCongo",
      "type": "mediacongo-scraper",
      "enabled": true,
      "recentUrl": "https://www.mediacongo.net/categories-cat-114_immobilier_vente_location-page-1.html",
      "popularUrl": "https://www.mediacongo.net/",
      "maxPages": 3,
      "fetchDetails": true,
      "requestDelayMs": 500,
      "defaultCategory": "immobilier",
      "defaultCity": "Kinshasa",
      "defaultModality": "rent"
    },
    {
      "name": "Zwandako Kinshasa scraper",
      "provider": "zwandako",
      "providerName": "Zwandako",
      "type": "zwandako-scraper",
      "enabled": true,
      "recentUrl": "https://zwandako.com/immobilier/feed/",
      "popularUrl": "https://zwandako.com/resultats-de-recherche/?status%5B%5D=a-louer&location%5B%5D=kinshasa",
      "maxPages": 3,
      "fetchDetails": true,
      "requestDelayMs": 400,
      "defaultCategory": "immobilier",
      "defaultCity": "Kinshasa",
      "defaultModality": "rent"
    },
    {
      "name": "Jiji RDC Kinshasa scraper",
      "provider": "jiji_rdc",
      "providerName": "Jiji RDC",
      "type": "jiji-scraper",
      "enabled": false,
      "recentUrl": "https://jiji.cd/kinshasa/immobilier",
      "maxPages": 3,
      "fetchDetails": true,
      "requestDelayMs": 600,
      "headers": {
        "Cookie": "${JIJI_COOKIE}"
      },
      "defaultCategory": "immobilier",
      "defaultCity": "Kinshasa",
      "defaultModality": "rent"
    },
    {
      "name": "Facebook Marketplace Kinshasa (Apify)",
      "provider": "facebook_marketplace",
      "providerName": "Facebook Marketplace",
      "type": "apify-facebook-scraper",
      "enabled": false,
      "apifyToken": "${APIFY_TOKEN}",
      "apifyActorId": "apify/facebook-marketplace-scraper",
      "marketplaceLocation": "kinshasa",
      "searchQueries": [
        "appartement",
        "maison",
        "immobilier",
        "parcelle"
      ],
      "resultsLimit": 75,
      "fetchDetails": true,
      "actorTimeoutSeconds": 300,
      "defaultCategory": "immobilier",
      "defaultCity": "Kinshasa",
      "defaultModality": "rent"
    },
    {
      "name": "LinkedIn Jobs Kinshasa (Apify)",
      "provider": "linkedin_jobs",
      "providerName": "LinkedIn Jobs",
      "type": "apify-linkedin-jobs-scraper",
      "enabled": false,
      "apifyToken": "${APIFY_TOKEN}",
      "apifyActorId": "curious_coder/linkedin-jobs-scraper",
      "linkedInGeoId": "107853273",
      "resultsLimit": 100,
      "maxAdvertAgeDays": 30,
      "fetchDetails": false,
      "actorTimeoutSeconds": 300,
      "defaultCategory": "emploi_services",
      "defaultSubcategory": "offre_emploi",
      "defaultCity": "Kinshasa",
      "defaultModality": "offre"
    },
    {
      "name": "Facebook Marketplace approved export",
      "provider": "facebook_marketplace",
      "providerName": "Facebook Marketplace",
      "type": "facebook-approved-feed",
      "enabled": false,
      "recentUrl": "https://partner-or-internal-feed.example.com/facebook/kinshasa/recent.json",
      "popularUrl": "https://partner-or-internal-feed.example.com/facebook/kinshasa/popular.json",
      "headers": {
        "Authorization": "Bearer ${FACEBOOK_APPROVED_FEED_TOKEN}"
      },
      "defaultCategory": "immobilier",
      "defaultSubcategory": "appartement_a_louer",
      "defaultCity": "Kinshasa",
      "defaultModality": "rent"
    },
    {
      "name": "MediaCongo RSS",
      "provider": "mediacongo",
      "providerName": "MediaCongo",
      "type": "rss",
      "enabled": false,
      "recentUrl": "https://www.mediacongo.net/rss/annonces.xml",
      "popularUrl": null,
      "defaultCategory": "immobilier",
      "defaultCity": "Kinshasa",
      "defaultModality": "rent"
    },
    {
      "name": "Generic Kinshasa adverts JSON feed",
      "provider": "other",
      "providerName": "Partner Source",
      "type": "json-feed",
      "enabled": false,
      "recentUrl": "https://partner.example.com/kinshasa/adverts/recent.json",
      "popularUrl": "https://partner.example.com/kinshasa/adverts/popular.json",
      "defaultCategory": "immobilier",
      "defaultCity": "Kinshasa",
      "defaultModality": "rent"
    }
  ]
}
