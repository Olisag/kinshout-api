{
  "kinshoutApi": {
    "baseUrl": "http://localhost:5280",
    "importPath": "/api/imports/adverts",
    "knownAdvertsPath": "/api/imports/known-adverts",
    "importDiscussionsPath": "/api/imports/discussions",
    "knownDiscussionsPath": "/api/imports/known-discussions",
    "discussionImportStatePath": "/api/imports/discussion-import-state",
    "discussionImportRunsPath": "/api/imports/discussion-import-runs",
    "importKey": "dev-kinshout-import-secret-change-me",
    "batchSize": 100
  },
  "schedule": {
    "runOnce": false,
    "intervalHours": 360,
    "timeZoneId": "Africa/Kinshasa",
    "skipExisting": true,
    "detectRemovedListings": true,
    "maxAdvertAgeDays": 60,
    "maxDiscussionAgeDays": 7
  },
  "providers": [
    {
      "name": "MediaCongo Kinshasa scraper",
      "provider": "mediacongo",
      "providerName": "MediaCongo",
      "type": "mediacongo-scraper",
      "enabled": false,
      "recentUrl": "https://www.mediacongo.net/categories-cat-114_immobilier_vente_location-page-1.html",
      "popularUrl": "https://www.mediacongo.net/",
      "extraListingUrls": [
        "https://www.mediacongo.net/categories-cat-101_telephones_tablettes_et_accessoires-page-1.html",
        "https://www.mediacongo.net/categories-cat-102_ordinateurs_informatique_tv_hi_fi_electronique-page-1.html",
        "https://www.mediacongo.net/categories-cat-105_automobile_motos_velos_engins_et_pieces-page-1.html",
        "https://www.mediacongo.net/categories-cat-4_recherche_d_emploi-page-1.html",
        "https://www.mediacongo.net/categories-cat-3_services_propositions_d_affaires-page-1.html",
        "https://www.mediacongo.net/categories-cat-103_pour_la_maison_meubles_decoration_electromenager-page-1.html"
      ],
      "maxPages": 2,
      "fetchDetails": true,
      "requestDelayMs": 500,
      "defaultCategory": "other",
      "defaultCity": "Kinshasa",
      "defaultModality": "sale"
    },
    {
      "name": "Zwandako Kinshasa scraper",
      "provider": "zwandako",
      "providerName": "Zwandako",
      "type": "zwandako-scraper",
      "enabled": true,
      "recentUrl": "https://zwandako.com/immobilier/feed/",
      "popularUrl": "https://zwandako.com/resultats-de-recherche/?status%5B%5D=a-louer&location%5B%5D=kinshasa",
      "maxPages": 3,
      "fetchDetails": true,
      "requestDelayMs": 400,
      "defaultCategory": "immobilier",
      "defaultCity": "Kinshasa",
      "defaultModality": "rent"
    },
    {
      "name": "Facebook Marketplace Kinshasa (Apify)",
      "provider": "facebook_marketplace",
      "providerName": "Facebook Marketplace",
      "type": "apify-facebook-scraper",
      "enabled": true,
      "apifyToken": "${APIFY_TOKEN}",
      "apifyActorId": "apify/facebook-marketplace-scraper",
      "marketplaceLocation": "113766458633901",
      "searchQueries": [
        "appartement",
        "maison",
        "immobilier",
        "parcelle",
        "iphone",
        "samsung",
        "voiture",
        "moto",
        "ordinateur",
        "macbook",
        "emploi",
        "meuble"
      ],
      "extraListingUrls": [
        "electronics",
        "vehicles",
        "propertyrentals",
        "propertyforsale",
        "home",
        "apparel"
      ],
      "resultsLimit": 25,
      "fetchDetails": false,
      "actorTimeoutSeconds": 300,
      "defaultCategory": "other",
      "defaultCity": "Kinshasa",
      "defaultModality": "sale"
    },
    {
      "name": "LinkedIn Jobs Kinshasa (Apify)",
      "provider": "linkedin_jobs",
      "providerName": "LinkedIn Jobs",
      "type": "apify-linkedin-jobs-scraper",
      "enabled": true,
      "apifyToken": "${APIFY_TOKEN}",
      "apifyActorId": "curious_coder/linkedin-jobs-scraper",
      "linkedInGeoId": "107853273",
      "resultsLimit": 100,
      "maxAdvertAgeDays": 30,
      "fetchDetails": false,
      "actorTimeoutSeconds": 300,
      "defaultCategory": "emploi_services",
      "defaultSubcategory": "offre_emploi",
      "defaultCity": "Kinshasa",
      "defaultModality": "offre"
    }
  ],
  "discussionProviders": [
    {
      "name": "Facebook Kinshasa posts (Apify)",
      "provider": "facebook",
      "providerName": "Facebook",
      "type": "apify-facebook-posts-scraper",
      "enabled": true,
      "apifyToken": "${APIFY_TOKEN}",
      "apifyActorId": "scraper_one/facebook-posts-search",
      "searchQueries": ["Kinshasa"],
      "popularUrl": "top",
      "resultsLimit": 50,
      "maxAdvertAgeDays": 7,
      "minEngagementScore": 20,
      "fetchDetails": false,
      "actorTimeoutSeconds": 300,
      "defaultCity": "Kinshasa"
    },
    {
      "name": "X Kinshasa posts (Apify)",
      "provider": "twitter",
      "providerName": "X",
      "type": "apify-twitter-posts-scraper",
      "enabled": true,
      "apifyToken": "${APIFY_TOKEN}",
      "apifyActorId": "seemuapps/x-tweet-scraper",
      "searchQueries": ["Kinshasa lang:fr min_faves:5"],
      "recentUrl": "Top",
      "resultsLimit": 50,
      "maxAdvertAgeDays": 7,
      "minEngagementScore": 20,
      "fetchDetails": false,
      "actorTimeoutSeconds": 300,
      "defaultCity": "Kinshasa"
    }
  ]
}
